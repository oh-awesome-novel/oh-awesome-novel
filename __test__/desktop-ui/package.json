{
  "name": "@oh-awesome-novel/test-desktop-ui",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "pretest": "npm run build --workspace @oh-awesome-novel/client",
    "test": "vitest",
    "pretest:run": "npm run build --workspace @oh-awesome-novel/client",
    "test:run": "vitest run",
    "pretest:renderer-smoke": "npm run typecheck:renderer-smoke",
    "typecheck:renderer-smoke": "vue-tsc --noEmit -p ./renderer-smoke/tsconfig.json",
    "test:renderer-smoke": "node ./renderer-smoke/run.cjs"
  },
  "dependencies": {
    "@oh-awesome-novel/client": "^0.0.1",
    "vue": "^3.5.34",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/test-utils": "^2.4.11",
    "happy-dom": "^20.10.6",
    "typescript": "~6.0.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.8",
    "vue-tsc": "^3.2.8"
  }
}
