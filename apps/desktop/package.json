  "type": "commonjs",
  "main": ".vite/build/main.js",
  "scripts": {
    "dev": "npm --prefix ../.. run desktop:build:deps && electron-forge start",
    "package": "npm --prefix ../.. run desktop:build:package && electron-forge package",
