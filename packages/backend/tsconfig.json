{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "paths": {
      "@oh-awesome-novel/agent": [
        "../agent/src/index.ts"
      ],
      "@oh-awesome-novel/core": [
        "../core/src/index.ts"
      ],
      "@oh-awesome-novel/runtime": [
        "../runtime/src/index.ts"
      ],
      "@oh-awesome-novel/tools": [
        "../tools/src/index.ts"
      ]
    },
    "lib": [
      "ES2022",
      "DOM"
    ],
    "types": [
      "node"
    ],
    "strict": true,
    "erasableSyntaxOnly": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "include": [
    "src/**/*.ts",
    "tsdown.config.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
